{
  "name": "nexxaura-main-server",
  "version": "1.0.0",
  "description": "MVC API for Office Ally appointment sync",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "worker": "node src/worker.js",
    "test": "jest --runInBand",
    "test:ci": "jest --ci --runInBand --coverage"
  },
  "keywords": [
    "express",
    "office-ally",
    "playwright",
    "postgres",
    "redis"
  ],
  "author": "",
  "license": "ISC",
  "jest": {
    "setupFiles": [
      "<rootDir>/tests/setup.js"
    ],
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coveragePathIgnorePatterns": [
      "src/server.js"
    ],
    "coverageReporters": [
      "text",
      "lcov"
    ]
  },
  "dependencies": {
    "@sentry/node": "^10.51.0",
    "@sentry/profiling-node": "^10.51.0",
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.41.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.0",
    "form-data": "^4.0.5",
    "graphql": "^16.13.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "playwright": "^1.59.1",
    "prom-client": "^15.1.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
