{
  "uid": "nexxaura-a-overview",
  "title": "A) Global overview (Node + FastAPI)",
  "description": "Combined and split RPS, errors, and latency. Wire Celery to Prometheus for the jobs section.",
  "tags": ["nexxaura", "A", "overview"],
  "schemaVersion": 38,
  "version": 1,
  "editable": true,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "links": [
    { "title": "Node HTTP", "type": "link", "url": "/d/nexxaura-b-node-http" },
    { "title": "Grafana", "type": "link", "url": "/dashboards" }
  ],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "RPS (split by service label on HTTP total)",
      "datasource": { "type": "prometheus", "uid": "prom-default" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prom-default" },
          "expr": "sum by (service) (rate(http_requests_total[5m])) or vector(0)",
          "refId": "A",
          "legendFormat": "{{ service }}"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "5xx rate (HTTP status ~5xx)",
      "datasource": { "type": "prometheus", "uid": "prom-default" },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) or vector(0)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "p95 Node HTTP (s) — from histogram (approx)",
      "datasource": { "type": "prometheus", "uid": "prom-default" },
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Redis used memory (bytes) — from redis-exporter or Node INFO gauge",
      "datasource": { "type": "prometheus", "uid": "prom-default" },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 8 },
      "targets": [
        { "expr": "max(redis_memory_used_bytes) or max(redis_used_memory_bytes) or vector(0)", "refId": "A" }
      ]
    }
  ]
}
