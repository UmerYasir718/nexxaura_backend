{
  "info": {
    "name": "Nexxaura User Credential Settings",
    "description": "Single user settings API for Office Ally (EHR) and Availity (Payer Portal).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Save credentials (Office Ally + Availity)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"companyName\": \"Office Ally\",\n  \"title\": \"EHR\",\n  \"description\": \"Primary EHR login\",\n  \"name\": \"Front Desk User\",\n  \"officeallyusernameOrEmail\": \"officeally_user@example.com\",\n  \"officeallyPassword\": \"fdf\",\n  \"availityusernameOrEmail\": \"availity_user@example.com\",\n  \"availityPassword\": \"fdfd\",\n  \"password\": \"oaStrongPassword123\"\n}"
        },
        "url": "{{baseUrl}}/api/users/credentials"
      }
    }
  ]
}
